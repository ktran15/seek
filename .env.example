# Copy to .env and fill in from the Supabase dashboard (Project Settings → API).
# EXPO_PUBLIC_* vars are bundled into the client — ONLY client-safe values here.
# The publishable key is designed to be public; RLS is the security boundary.
# NEVER put the service-role key, image-generation API key, or any other secret
# in this file or anywhere client-side — those live in Edge Function env only.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
